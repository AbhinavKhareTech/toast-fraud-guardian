# toast-fraud-guardian environment configuration
# Copy to .env and fill in values

# --- Application ---
APP_ENV=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# --- Database ---
DATABASE_URL=postgresql+asyncpg://fraud_user:fraud_pass@localhost:5432/fraud_guardian
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_FEATURE_STORE_DB=1
REDIS_SEQUENCE_CACHE_DB=2
REDIS_MAX_CONNECTIONS=50

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/3
CELERY_RESULT_BACKEND=redis://localhost:6379/4

# --- ML / Inference ---
ONNX_MODEL_PATH=./ml/export/fraud_scorer_v1.onnx
FRAUD_SCORE_THRESHOLD_AUTO=0.85
FRAUD_SCORE_THRESHOLD_REVIEW=0.50
MODEL_VERSION=v1.0.0

# --- LLM ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# --- Payment Integrations ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
SQUARE_ACCESS_TOKEN=
SQUARE_WEBHOOK_SIGNATURE_KEY=
# Toast: interface-first, sandbox only until API docs available
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
TOAST_ENVIRONMENT=sandbox

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=toast-fraud-guardian
PROMETHEUS_PORT=9090

# --- Compliance ---
PII_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=2555
ENABLE_GDPR_DELETION=true

# --- Feature Flags ---
FF_AUTO_SUBMIT_DISPUTES=false
FF_SEQUENCE_MODEL_ENABLED=true
FF_LLM_EVIDENCE_WRITER=true
FF_AB_TEST_SCORING=false
